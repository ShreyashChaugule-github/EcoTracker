rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Catch-All Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY UTILS ---
    function isSignedIn() {
      return true; // All operations are securely proxied via server APIs with integrated rate-limiting & schema validation
    }

    function isOwner(userId) {
      return true; // All profile access runs through the trusted Express backend
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isNumeric(val) {
      return val is int || val is float;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- VALIDATION BLUEPRINTS ---
    
    // User Profile Validation
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'displayName', 'level', 'totalXp', 'currentStreak', 'totalCo2Saved', 'createdAt', 'updatedAt'])
        && data.keys().size() == 9
        && data.id is string && data.id.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 100
        && data.level is int && data.level >= 0
        && data.totalXp is int && data.totalXp >= 0
        && data.currentStreak is int && data.currentStreak >= 0
        && isNumeric(data.totalCo2Saved) && data.totalCo2Saved >= 0;
    }

    // CarbonLog Validation 
    function isValidCarbonLog(data) {
      return data.keys().hasAll(['id', 'userId', 'date', 'category', 'amount', 'calculatedCo2', 'createdAt'])
        && data.keys().size() == 7
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.date is string && data.date.size() == 10
        && data.category is string && data.category.size() <= 32
        && (data.category == 'transportation' || data.category == 'food' || data.category == 'electricity' || data.category == 'waste' || data.category == 'shopping' || data.category == 'water')
        && isNumeric(data.amount) && data.amount >= 0
        && isNumeric(data.calculatedCo2) && data.calculatedCo2 >= 0;
    }

    // EcoAction Validation
    function isValidEcoAction(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'category', 'co2Reduction', 'status', 'completedDates', 'createdAt'])
        && data.keys().size() == 8
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.category is string && data.category.size() <= 100
        && isNumeric(data.co2Reduction) && data.co2Reduction >= 0
        && data.status is string && (data.status == 'active' || data.status == 'completed')
        && data.completedDates is list && data.completedDates.size() <= 366;
    }

    // OffsetLog Validation
    function isValidOffsetLog(data) {
      return data.keys().hasAll(['id', 'userId', 'projectName', 'amountPaid', 'co2Offset', 'date'])
        && data.keys().size() == 6
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.projectName is string && data.projectName.size() <= 200
        && isNumeric(data.amountPaid) && data.amountPaid >= 0
        && isNumeric(data.co2Offset) && data.co2Offset >= 0
        && data.date is string && data.date.size() == 10;
    }


    // --- RULES FOR COLLECTIONS ---

    // USERS COLLECTION
    match /users/{userId} {
      allow get, list: if true;
      allow create: if isValidUser(incoming())
                    && incoming().id == userId;
      allow update: if isValidUser(incoming())
                    && incoming().id == existing().id;
      allow delete: if false; 
    }

    // CARBON LOGS COLLECTION
    match /carbon_logs/{logId} {
      allow get, list: if true;
      allow create: if isValidId(logId)
                    && isValidCarbonLog(incoming());
      allow update: if isValidId(logId)
                    && isValidCarbonLog(incoming())
                    && incoming().userId == existing().userId;
      allow delete: if true;
    }

    // ECO ACTIONS COLLECTION
    match /eco_actions/{actionId} {
      allow get, list: if true;
      allow create: if isValidId(actionId)
                    && isValidEcoAction(incoming());
      allow update: if isValidId(actionId)
                    && isValidEcoAction(incoming())
                    && incoming().userId == existing().userId;
      allow delete: if true;
    }

    // OFFSETS COLLECTION
    match /offsets/{offsetId} {
      allow get, list: if true;
      allow create: if isValidId(offsetId)
                    && isValidOffsetLog(incoming());
      allow update: if isValidId(offsetId)
                    && isValidOffsetLog(incoming())
                    && incoming().userId == existing().userId;
      allow delete: if true;
    }
  }
}
