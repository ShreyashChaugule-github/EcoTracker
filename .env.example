# ============================================================
# EcoTracker — Environment Variables
# Copy this file to .env for local development.
# For Cloud Run, set these as environment variables / secrets
# in the Google Cloud Console or via gcloud CLI.
# ============================================================

# --- Gemini AI via Vertex AI ---
# NO API KEY NEEDED. Vertex AI uses Application Default Credentials (ADC).
# On Cloud Run: the service account is used automatically.
# Locally: run `gcloud auth application-default login` once.
#
# GCP project that has Vertex AI API enabled
VERTEX_PROJECT="ecotracker-499709"
# Vertex AI region (must match where the model is available)
VERTEX_LOCATION="us-central1"

# --- App URL ---
# The public URL of this service (injected automatically by Cloud Run).
APP_URL="https://your-service-url.run.app"

# ============================================================
# Firebase / Firestore Configuration
# These replace firebase-applet-config.json in production.
# Find all values in: Firebase Console → Project Settings → General
# ============================================================

# Web API key (Firebase Console → Project Settings → Web API key)
FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"

# e.g. your-project.firebaseapp.com
FIREBASE_AUTH_DOMAIN="ecotracker-499709.firebaseapp.com"

# GCP project ID
FIREBASE_PROJECT_ID="ecotracker-499709"

# e.g. your-project.firebasestorage.app
FIREBASE_STORAGE_BUCKET="ecotracker-499709.firebasestorage.app"

# Numeric sender ID from Firebase Console
FIREBASE_MESSAGING_SENDER_ID="853463380014"

# App ID from Firebase Console (format: 1:SENDER:web:HASH)
FIREBASE_APP_ID="1:853463380014:web:b9dde8cd779b9d7f66efbf"

# Optional — Analytics measurement ID
FIREBASE_MEASUREMENT_ID="G-8P6KGHLH6E"

# Named Firestore database ID (leave as "(default)" if using the default DB)
# Set to "ecotracker" to use your custom named database
FIRESTORE_DATABASE_ID="ecotracker"

# ============================================================
# Client-side (Vite) — these are baked into the frontend bundle
# at build time. They MUST be prefixed with VITE_.
# Duplicate of the FIREBASE_* vars above, for the browser build.
# ============================================================
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="ecotracker-499709.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="ecotracker-499709"
VITE_FIREBASE_STORAGE_BUCKET="ecotracker-499709.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="853463380014"
VITE_FIREBASE_APP_ID="1:853463380014:web:b9dde8cd779b9d7f66efbf"
VITE_FIREBASE_MEASUREMENT_ID="G-8P6KGHLH6E"
VITE_FIRESTORE_DATABASE_ID="ecotracker"
